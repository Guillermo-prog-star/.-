# .env.example — copia a .env y completa los valores reales
# NUNCA comitear .env al repositorio

# ── Base de datos ─────────────────────────────────────────
DB_HOST=if-mysql
DB_PORT=3306
DB_NAME=integrity_family
DB_USER=root
# PROD: usar contraseña fuerte de al menos 24 caracteres
DB_PASSWORD=root

# ── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_HOST=if-rabbitmq
RABBITMQ_USER=guest
# PROD: cambiar a contraseña segura
RABBITMQ_PASSWORD=guest

# ── Seguridad JWT ─────────────────────────────────────────
# CRÍTICO: generar con: openssl rand -base64 64
# NUNCA usar el valor por defecto en producción
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# ── CORS ─────────────────────────────────────────────────
# Dev: http://localhost:4200
# Prod: https://tudominio.com (sin barra final)
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# ── Errores del servidor ───────────────────────────────────
# Dev: always | Prod: never  (evita exponer stack traces)
SERVER_ERROR_INCLUDE_MESSAGE=always
SERVER_ERROR_INCLUDE_BINDING_ERRORS=always

# ── IA: Claude (Anthropic) ────────────────────────────────
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ── IA: Voz (opcional) ────────────────────────────────────
# Para activar: SPRING_PROFILES_ACTIVE=voice
WHISPER_ENABLED=false
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1

ELEVENLABS_ENABLED=false
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# ── Perfil Spring Boot ────────────────────────────────────
# Dev: default | Prod: prod | Railway: railway | Render: render
SPRING_PROFILES_ACTIVE=default
