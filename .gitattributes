# Normalize line endings: store as LF in the repo, let Windows checkout as CRLF
# and Linux/macOS checkout as LF.

# Default: auto-detect text files and normalize
* text=auto

# Explicit text files — always LF in repo
*.ts    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.java  text eol=lf
*.sql   text eol=lf
*.xml   text eol=lf
*.sh    text eol=lf
*.py    text eol=lf
*.conf  text eol=lf
Dockerfile* text eol=lf

# Windows-specific scripts — keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary files — no line-ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.otf   binary
*.jar   binary
*.war   binary
*.class binary
*.pdf   binary
*.zip   binary
