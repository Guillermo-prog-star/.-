{
	"info": {
		"_postman_id": "a9a8d5e1-8890-48e0-bb15-bbf07b22d119",
		"name": "Integrity Family API",
		"description": "Colección centralizada para interactuar y validar el Nodo Integrity Family (Spring Boot + RabbitMQ).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"william@integrity.family\",\n    \"password\": \"Admin123*\"\n}"
						},
						"url": {
							"raw": "http://localhost:8080/api/auth/login",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "8080",
							"path": [ "api", "auth", "login" ]
						}
					}
				}
			]
		},
		{
			"name": "2. Analíticas (Requiere Bearer Token)",
			"item": [
				{
					"name": "Resumen por Familia",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": {
							"raw": "http://localhost:8080/api/analytics/dashboard/family/1",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "8080",
							"path": [ "api", "analytics", "dashboard", "family", "1" ]
						}
					}
				}
			]
		},
		{
			"name": "3. RabbitMQ Testing",
			"item": [
				{
					"name": "Verificar Salud",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8080/actuator/health",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "8080",
							"path": [ "actuator", "health" ]
						}
					}
				}
			]
		}
	],
	"variable": [
		{ "key": "jwt_token", "value": "aqui_tu_token_generado_en_login" }
	]
}
